<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Finding Detail </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
        }

        .bg-gradient-vulnerability {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
        }
    </style>
</head>

<body class="p-4 md:p-8">
    <div class="max-w-4xl mx-auto">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-4 mb-8">
            <a href="/dashboard/scan/<%= finding.scanId %>"
                class="bg-white p-2 rounded-lg border border-slate-200 hover:bg-slate-50 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
            </a>
            <div class="flex flex-col">
                <span class="text-[10px] font-black uppercase text-slate-400 tracking-widest">VULNERABILITY INTELLIGENCE
                    ANALYZER</span>
                <h1 class="text-xl font-black text-slate-800 tracking-tight leading-none">
                    <%= finding.description %>
                </h1>
            </div>
        </div>

        <!-- Main Card -->
        <div class="bg-white rounded-3xl shadow-2xl border border-slate-200 overflow-hidden mb-8">
            <div class="p-8 bg-gradient-vulnerability text-white flex items-center justify-between gap-6">
                <div class="flex flex-col gap-2">
                    <% const sevClass=finding.severity==='CRITICAL' || finding.severity==='HIGH'
                        ? 'bg-red-500 text-white' : (finding.severity==='MEDIUM' ? 'bg-orange-500 text-black'
                        : 'bg-blue-500 text-white' ); %>
                        <span
                            class="inline-block text-[11px] font-black uppercase px-3 py-1 rounded shadow-lg <%= sevClass %> w-fit tracking-tighter">
                            <%= finding.severity %> RISK DETECTED
                        </span>
                        <h2 class="text-3xl font-black leading-tight">
                            <%= finding.description %>
                        </h2>
                        <div class="flex gap-4 items-center text-slate-400 text-xs font-mono mt-4">
                            <span class="flex items-center gap-2">
                                <div class="h-2 w-2 rounded-full bg-blue-500"></div> SOURCE: <%=
                                    finding.toolName.toUpperCase() %>
                            </span>
                            <% if (finding.owaspCategory) { %>
                                <span
                                    class="flex items-center gap-2 font-bold decoration-blue-500 underline underline-offset-4">🛡️
                                    <%= finding.owaspCategory %></span>
                                <% } %>
                        </div>
                </div>
                <div
                    class="hidden md:flex flex-col items-center justify-center h-28 w-28 bg-white/5 border border-white/10 rounded-2xl backdrop-blur-sm">
                    <span class="text-[9px] font-black uppercase text-slate-500 mb-1">SCORE IMPACT</span>
                    <span class="text-4xl font-black">
                        <%= finding.severity==='HIGH' ? '-10' : (finding.severity==='MEDIUM' ? '-5' : '-1' ) %>
                    </span>
                </div>
            </div>

            <div class="p-8">
                <div class="grid grid-cols-1 gap-8">
                    <!-- Evidence -->
                    <section>
                        <h3
                            class="text-[10px] font-black text-slate-400 uppercase mb-4 tracking-[0.4em] flex items-center gap-2">
                            <span class="h-1.5 w-1.5 bg-red-500 rounded-full animate-pulse"></span>
                            TECHNICAL EVIDENCE & TRACE
                        </h3>
                        <div class="bg-slate-900 rounded-2xl p-6 overflow-x-auto shadow-inner border border-slate-800">
                            <code
                                class="text-sm font-mono text-green-400 whitespace-pre scrollbar-hide block"><%= finding.evidence || 'No direct technical trace recorded during the scan phase.' %></code>
                        </div>
                    </section>

                    <!-- Recommendation -->
                    <section class="bg-blue-50/50 p-8 rounded-2xl border border-blue-100">
                        <h3
                            class="text-[10px] font-black text-blue-500 uppercase mb-4 tracking-[0.4em] flex items-center gap-2">
                            REMEDIATION PROTOCOL
                        </h3>
                        <p class="text-sm font-semibold text-slate-700 leading-relaxed mb-4">
                            <%= finding.recommendation
                                || 'Standard enterprise security patching and OWASP Top 10 mitigation guidelines apply to this finding.'
                                %>
                        </p>
                        <div class="flex gap-4">
                            <div class="flex-1 p-4 bg-white rounded-xl border border-blue-200">
                                <div class="text-[9px] font-black text-blue-400 uppercase mb-1">Impact Level</div>
                                <div class="text-xs font-bold text-slate-800">Operational Integrity at Risk</div>
                            </div>
                            <div class="flex-1 p-4 bg-white rounded-xl border border-blue-200">
                                <div class="text-[9px] font-black text-blue-400 uppercase mb-1">Complexity</div>
                                <div class="text-xs font-bold text-slate-800">Medium patching required</div>
                            </div>
                        </div>
                    </section>
                    
                    <!-- Triage Command Center -->
                    <section class="bg-slate-50 p-8 rounded-2xl border border-slate-200 mt-2 shadow-inner">
                        <h3 class="text-[10px] font-black text-slate-500 uppercase mb-4 tracking-[0.4em] flex items-center gap-2">
                            <span class="h-1.5 w-1.5 bg-indigo-500 rounded-full"></span>
                            TRIAGE COMMAND CENTER
                        </h3>
                        <div class="flex flex-col gap-4">
                            <div class="flex items-center gap-3 bg-white p-3 rounded-xl border border-slate-200 w-fit">
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">CURRENT STATUS:</span>
                                <% const statusColor = finding.status === 'FALSE_POSITIVE' ? 'bg-slate-200 text-slate-600' : (finding.status === 'ACCEPTED_RISK' ? 'bg-amber-100 text-amber-600' : (finding.status === 'RESOLVED' ? 'bg-emerald-100 text-emerald-600' : 'bg-red-100 text-red-600')) %>
                                <span class="text-[11px] font-black uppercase px-2 py-1 rounded <%= statusColor %>">
                                    <%= finding.status || 'OPEN' %>
                                </span>
                            </div>
                            
                            <div class="flex flex-wrap gap-4 mt-2">
                                <% if (finding.status !== 'FALSE_POSITIVE') { %>
                                    <button onclick="updateStatus('FALSE_POSITIVE')" class="px-6 py-3 bg-slate-800 text-white text-[11px] font-black uppercase tracking-wider rounded-xl hover:bg-slate-700 transition shadow-lg hover:shadow-xl hover:-translate-y-0.5">Mark as False Positive</button>
                                <% } %>
                                <% if (finding.status !== 'ACCEPTED_RISK') { %>
                                    <button onclick="updateStatus('ACCEPTED_RISK')" class="px-6 py-3 bg-amber-500 text-white text-[11px] font-black uppercase tracking-wider rounded-xl hover:bg-amber-600 transition shadow-lg hover:shadow-xl hover:-translate-y-0.5">Accept Risk</button>
                                <% } %>
                                <% if (finding.status !== 'RESOLVED') { %>
                                    <button onclick="updateStatus('RESOLVED')" class="px-6 py-3 bg-emerald-500 text-white text-[11px] font-black uppercase tracking-wider rounded-xl hover:bg-emerald-600 transition shadow-lg hover:shadow-xl hover:-translate-y-0.5">Mark Resolved</button>
                                <% } %>
                                <% if (finding.status !== 'OPEN') { %>
                                    <button onclick="updateStatus('OPEN')" class="px-6 py-3 bg-blue-500 text-white text-[11px] font-black uppercase tracking-wider rounded-xl hover:bg-blue-600 transition shadow-lg hover:shadow-xl hover:-translate-y-0.5">Re-Open Finding</button>
                                <% } %>
                            </div>
                        </div>
                    </section>
                    
                    <!-- AI Assistant Integration -->
                    <section class="bg-gradient-to-r from-violet-900 to-fuchsia-900 p-8 rounded-2xl border border-violet-800 text-white shadow-xl relative overflow-hidden">
                        <div class="absolute top-0 right-0 p-4 opacity-10">
                            <svg class="h-32 w-32" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/></svg>
                        </div>
                        <h3 class="text-[10px] font-black text-fuchsia-300 uppercase mb-4 tracking-[0.4em] flex items-center gap-2 relative z-10">
                            <span class="h-1.5 w-1.5 bg-fuchsia-400 rounded-full animate-pulse"></span>
                            AI AUTO-REMEDIATION ENGINE
                        </h3>
                        <p class="text-sm font-medium text-violet-200 mb-6 relative z-10 max-w-2xl">
                            Deploy our Neural Engine to instantly analyze this vulnerability context and generate a deterministic code-level solution or detailed mitigation command sequence.
                        </p>
                        
                        <button id="askAiBtn" onclick="askAiToFix()" class="relative z-10 px-6 py-3 bg-white text-violet-900 text-xs font-black uppercase tracking-wider rounded-xl hover:bg-violet-100 transition shadow-lg flex items-center gap-2">
                           <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                              <path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd" />
                           </svg>
                           Generate Exact Fix Strategy
                        </button>

                        <div id="aiLoading" class="hidden relative z-10 mt-6 flex items-center gap-3 text-fuchsia-200 text-sm font-mono">
                            <svg class="animate-spin h-5 w-5 text-fuchsia-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
                            Synthesizing technical solution...
                        </div>

                        <div id="aiResponsePanel" class="hidden relative z-10 mt-6 bg-slate-900/80 backdrop-blur border border-white/10 rounded-xl p-6 text-sm text-slate-300 font-mono shadow-inner overflow-x-auto leading-relaxed prose prose-invert max-w-none">
                            <!-- Markdown is rendered here -->
                        </div>
                    </section>
                </div>
            </div>
        </div>

        <div
            class="flex justify-between items-center text-[10px] font-mono font-bold text-slate-400 uppercase tracking-widest px-4">
            <span>Finding ID: <%= finding.id %></span>
            <span>Scan Parent: <%= finding.scanId %></span>
        </div>
    </div>

    <script>
        async function updateStatus(newStatus) {
            if (!confirm(`Are you sure you want to change the status to ${newStatus}? This will recalculate the global scan risk score.`)) return;
            
            try {
                const response = await fetch(`/dashboard/finding/<%= finding.id %>/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        status: newStatus, 
                        resolutionNote: 'Updated via Triage Command Center by Fleet Commander.' 
                    })
                });
                
                if (response.ok) {
                    window.location.reload();
                } else {
                    const err = await response.json();
                    alert(`Failed to update status: ${err.message || 'Unknown error'}`);
                }
            } catch (error) {
                console.error('Error updating status:', error);
                alert('An error occurred while communicating with the orchestrator.');
            }
        }

        async function askAiToFix() {
            const btn = document.getElementById('askAiBtn');
            const loading = document.getElementById('aiLoading');
            const panel = document.getElementById('aiResponsePanel');
            
            btn.style.display = 'none';
            loading.style.display = 'flex';
            panel.style.display = 'none';

            try {
                // Configuração base do interpretador Markdown para evitar vulnerabilidades de CSS nativo
                marked.setOptions({ breaks: true, gfm: true });

                const res = await fetch(`/ai/remediate/<%= finding.id %>`, { method: 'POST' });
                const data = await res.json();
                
                loading.style.display = 'none';
                panel.style.display = 'block';
                
                if (data.success) {
                    panel.innerHTML = marked.parse(data.aiAdvice);
                } else {
                    panel.innerHTML = `<span class="text-red-400">Error: Could not retrieve AI response.</span>`;
                    btn.style.display = 'flex';
                }
            } catch (error) {
                loading.style.display = 'none';
                panel.style.display = 'block';
                panel.innerHTML = `<span class="text-red-400">Fatal error communicating with Neural Engine.</span>`;
                btn.style.display = 'flex';
            }
        }
    </script>
</body>
</html>