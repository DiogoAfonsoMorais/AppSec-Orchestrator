<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Project Details</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
        }
    </style>
</head>

<body class="p-6 md:p-12 min-h-screen bg-slate-50">
    <div class="max-w-6xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-12">
            <div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tight italic uppercase">AppSec Orchestrator</h1>
                <p class="text-slate-500 font-bold text-sm">Orchestrate and monitor your asset security projects</p>
                <div class="flex gap-4 mt-1">
                    <a href="/dashboard/monitoring"
                        class="text-[10px] font-black text-blue-600 uppercase tracking-widest hover:underline flex items-center gap-2">
                        <span class="h-2 w-2 rounded-full bg-blue-500 animate-pulse"></span>
                        Monitoring Active Scan
                    </a>
                </div>
            </div>
            <button onclick="document.getElementById('newProjectModal').classList.remove('hidden')"
                class="bg-slate-900 hover:bg-black text-white font-black px-8 py-4 rounded-2xl shadow-xl transition-all flex items-center gap-3 uppercase tracking-widest text-[10px]">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M12 4v16m8-8H4" />
                </svg>
                Deploy New project
            </button>
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
            <% projects.forEach(p=> { %>
                <div
                    class="project-container group bg-white rounded-[3rem] border-2 border-slate-100 shadow-sm hover:shadow-2xl hover:border-blue-500 transition-all overflow-hidden flex flex-col">
                    <a href="/dashboard/project/<%= p.id %>"
                        class="p-8 flex flex-col flex-1 hover:bg-slate-50/50 transition-colors">
                        <div class="flex justify-between items-start mb-6">
                            <div
                                class="h-14 w-14 rounded-[1.2rem] bg-white border border-slate-100 flex items-center justify-center text-2xl shadow-sm">
                                🛰️</div>
                            <div class="text-right">
                                <div
                                    class="text-[10px] font-black text-slate-400 uppercase tracking-widest leading-none mb-1">
                                    Health</div>
                                <div class="text-3xl font-black text-slate-900 leading-none">
                                    <%= p.stats.averageScore %>
                                </div>
                            </div>
                        </div>
                        <h3 class="text-2xl font-black text-slate-900 mb-2 tracking-tight uppercase">
                            <%= p.name %>
                        </h3>

                        <div class="flex items-center justify-between border-t-2 border-slate-50 pt-4 mt-auto">
                            <div class="flex flex-col">
                                <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Scan
                                    Count</span>
                                <span class="text-sm font-black text-slate-800">
                                    <%= p.stats.totalScans %>
                                </span>
                            </div>
                            <div class="flex flex-col text-right text-red-600">
                                <span class="text-[9px] font-black uppercase tracking-widest mb-1">Threats</span>
                                <span class="text-sm font-black">
                                    <%= p.stats.criticalFindings %>
                                </span>
                            </div>
                        </div>
                    </a>

                    <!-- Management -->
                    <div class="bg-slate-50 p-4 border-t-2 border-slate-100 flex gap-3 relative z-10">
                        <button
                            onclick="window.globalEditProject(event, '<%= p.id %>', '<%= p.name %>', '<%= p.description || '' %>')"
                            class="flex-1 bg-white hover:bg-blue-600 hover:text-white border-2 border-slate-100 py-2.5 rounded-xl transition-all flex items-center justify-center gap-2 text-[10px] font-black uppercase tracking-widest">
                            Edit
                        </button>
                        <button onclick="window.showDeleteModal('<%= p.id %>', '<%= p.name %>')"
                            class="bg-white hover:bg-red-600 hover:text-white border-2 border-slate-100 p-3 rounded-xl transition-all">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24"
                                stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
                <% }); %>
        </div>
    </div>

    <!-- MODAL: EDIT -->
    <div id="editProjectModal"
        class="hidden fixed inset-0 z-[150] flex items-center justify-center p-6 bg-slate-900/60 backdrop-blur-md">
        <div class="bg-white rounded-[3rem] w-full max-w-lg shadow-2xl overflow-hidden p-12">
            <h3 class="text-2xl font-black text-slate-900 mb-8 uppercase italic tracking-widest">Update Cluster</h3>
            <form id="editProjectForm" class="space-y-6">
                <input type="hidden" id="editProjectId">
                <input type="text" id="editName"
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-5 text-sm font-black outline-none focus:border-blue-500"
                    required>
                <textarea id="editDescription"
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-5 text-xs font-bold min-h-[120px] outline-none focus:border-blue-500"></textarea>
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="document.getElementById('editProjectModal').classList.add('hidden')"
                        class="flex-1 bg-white border border-slate-100 text-slate-400 font-black py-4 rounded-2xl uppercase text-[10px]">Abort</button>
                    <button type="submit"
                        class="flex-1 bg-blue-600 text-white font-black py-4 rounded-2xl shadow-xl uppercase text-[10px]">Sync
                        Change</button>
                </div>
            </form>
        </div>
    </div>

    <!-- MODAL: DELETE -->
    <div id="deleteConfirmModal"
        class="hidden fixed inset-0 z-[200] flex items-center justify-center p-6 bg-slate-950/90 backdrop-blur-xl">
        <div class="bg-white rounded-[3rem] w-full max-w-sm p-12 text-center shadow-2xl border-2 border-red-500">
            <div class="text-6xl mb-6">⚠️</div>
            <h3 class="text-2xl font-black text-slate-900 mb-2 uppercase italic">Delete Project?</h3>
            <p id="deleteTargetName" class="text-[9px] font-bold text-slate-400 mb-10 uppercase tracking-widest"></p>
            <div class="flex gap-4">
                <button onclick="document.getElementById('deleteConfirmModal').classList.add('hidden')"
                    class="flex-1 py-4 bg-slate-100 text-slate-400 font-black rounded-2xl uppercase text-[10px]">Cancel</button>
                <button id="finalDeleteBtn"
                    class="flex-1 py-4 bg-red-600 text-white font-black rounded-2xl shadow-lg uppercase text-[10px]">
                    Confirm</button>
            </div>
        </div>
    </div>

    <!-- MODAL: NEW -->
    <div id="newProjectModal"
        class="hidden fixed inset-0 z-[100] flex items-center justify-center p-6 bg-slate-900/60 backdrop-blur-md">
        <div class="bg-white rounded-[3rem] w-full max-w-lg shadow-2xl overflow-hidden p-12">

            <form id="projectForm" class="space-y-6">
                <input type="text" id="name" placeholder="Project Name"
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-5 text-sm font-black outline-none focus:border-blue-500 uppercase"
                    required>
                <textarea id="description" placeholder="Description..."
                    class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-5 text-xs font-bold min-h-[120px] outline-none focus:border-blue-500"></textarea>
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="document.getElementById('newProjectModal').classList.add('hidden')"
                        class="flex-1 bg-white border border-slate-100 text-slate-400 font-black py-4 rounded-2xl uppercase text-[10px]">Abort</button>
                    <button type="submit"
                        class="flex-1 bg-slate-900 text-white font-black py-4 rounded-2xl shadow-xl uppercase text-[10px]">Launch</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let pendingProjectDelete = null;

        window.showDeleteModal = function (id, name) {
            pendingProjectDelete = id;
            document.getElementById('deleteTargetName').textContent = name;
            document.getElementById('deleteConfirmModal').classList.remove('hidden');
        };

        document.getElementById('finalDeleteBtn').addEventListener('click', async () => {
            if (!pendingProjectDelete) return;
            try {
                const targetUrl = `${window.location.origin}/projects/${pendingProjectDelete}`;
                const res = await fetch(targetUrl, { method: 'DELETE' });
                if (res.ok) window.location.reload();
            } catch (err) { alert('HQ LINK JAMMED.'); }
        });

        window.globalEditProject = function (e, id, name, desc) {
            e.preventDefault(); e.stopPropagation();
            document.getElementById('editProjectId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editDescription').value = desc;
            document.getElementById('editProjectModal').classList.remove('hidden');
        };

        document.getElementById('editProjectForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('editProjectId').value;
            const res = await fetch(`${window.location.origin}/projects/${id}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: document.getElementById('editName').value,
                    description: document.getElementById('editDescription').value
                })
            });
            if (res.ok) window.location.reload();
        });

        document.getElementById('projectForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const res = await fetch(`${window.location.origin}/projects`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    name: document.getElementById('name').value,
                    description: document.getElementById('description').value
                })
            });
            if (res.ok) window.location.reload();
        });
    </script>

</body>

</html>