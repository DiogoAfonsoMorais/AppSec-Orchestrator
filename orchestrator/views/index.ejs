<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | <%= project.name %>
    </title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link
        href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Fira+Code:wght@400;500&display=swap"
        rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #f8fafc;
        }

        .font-mono {
            font-family: 'Fira Code', monospace;
        }

        .grade-A {
            color: #16a34a;
            background-color: #f0fdf4;
            border-color: #bbf7d0;
        }

        .grade-B {
            color: #2563eb;
            background-color: #eff6ff;
            border-color: #bfdbfe;
        }

        .grade-C {
            color: #ca8a04;
            background-color: #fefce8;
            border-color: #fef08a;
        }

        .grade-D {
            color: #ea580c;
            background-color: #fff7ed;
            border-color: #fed7aa;
        }

        .grade-F {
            color: #dc2626;
            background-color: #fef2f2;
            border-color: #fecaca;
        }

        .animate-scan {
            animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
        }

        .progress-bar-fill {
            transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .console-scrollbar::-webkit-scrollbar {
            width: 4px;
        }

        .console-scrollbar::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 10px;
        }

        @keyframes pulse {

            0%,
            100% {
                opacity: 1;
            }

            50% {
                opacity: .5;
            }
        }
    </style>
</head>

<body class="bg-slate-50 min-h-screen pb-20">
    <nav class="bg-slate-900 text-white py-4 px-8 sticky top-0 z-50 shadow-lg border-b border-blue-500/20">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-4">
                <a href="/dashboard"
                    class="bg-blue-600 p-2 rounded-xl hover:bg-blue-700 transition-all active:scale-95 shadow-lg shadow-blue-500/20">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                </a>
                <span class="text-xl font-black uppercase italic tracking-tighter">Project: <span class="text-blue-400">
                        <%= project.name %>
                    </span></span>
            </div>
            <div class="flex items-center gap-3 bg-slate-800/50 px-4 py-2 rounded-full border border-slate-700/50">
                <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                <span class="text-[9px] font-black uppercase tracking-widest text-slate-400 font-mono">LINK
                    STABLE</span>
            </div>
        </div>
    </nav>

    <main class="max-w-7xl mx-auto py-12 px-6">
        <div class="flex flex-col lg:flex-row gap-12">
            <!-- Form -->
            <div class="lg:w-1/3">
                <div class="bg-white p-10 rounded-[3rem] shadow-sm border-2 border-slate-100 sticky top-32">
                    <h2
                        class="text-xl font-black text-slate-900 mb-8 uppercase italic tracking-widest underline decoration-blue-500 decoration-8 underline-offset-4">
                        New Scan</h2>
                    <form id="scanForm" class="space-y-6">
                        <input type="hidden" id="projectId" value="<%= project.id %>">
                        <div>
                            <input type="text" id="target" placeholder="TARGET URL OR IMAGE..."
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-5 text-sm font-black outline-none focus:border-blue-500 shadow-inner"
                                required>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <select id="targetType"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-4 text-[10px] font-black outline-none appearance-none cursor-pointer">
                                <option value="WEB">Web App / API</option>
                                <option value="CONTAINER">Docker Image</option>
                                <option value="REPO">Source Code</option>
                            </select>
                            <select id="profile"
                                class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl p-4 text-[10px] font-black outline-none appearance-none cursor-pointer">
                                <option value="QUICK">Quick Audit</option>
                                <option value="FULL">Expert Pentest</option>
                            </select>
                        </div>
                        <button type="submit" id="submitBtn"
                            class="w-full bg-slate-900 hover:bg-black text-white font-black py-5 rounded-2xl shadow-xl transition-all uppercase tracking-widest text-[11px]">Run
                            Scan</button>
                    </form>
                </div>
            </div>

            <!-- List -->
            <div class="lg:w-2/3">
                <div class="flex items-center justify-between mb-10">
                    <h2 class="text-2xl font-black text-slate-900 uppercase italic tracking-tighter">Scans</h2>
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest"
                        id="lastUpdated">Telemetry Standby...</span>
                </div>
                <div id="scanList" class="space-y-8"></div>
            </div>
        </div>
    </main>

    <!-- Modal Abort -->
    <div id="abortConfirmModal"
        class="hidden fixed inset-0 z-[200] flex items-center justify-center p-6 bg-slate-900/90 backdrop-blur-xl">
        <div class="bg-white rounded-[3rem] w-full max-w-sm p-12 text-center shadow-2xl border-2 border-red-500">
            <div class="text-6xl mb-6">🛑</div>
            <h3 class="text-2xl font-black text-slate-900 mb-2 uppercase italic tracking-widest">Abort Run?</h3>
            <p id="abortScanIdText"
                class="text-[9px] font-bold text-slate-400 mb-10 uppercase tracking-widest font-mono"></p>
            <div class="flex gap-4">
                <button onclick="document.getElementById('abortConfirmModal').classList.add('hidden')"
                    class="flex-1 py-4 bg-slate-100 text-slate-400 font-black rounded-2xl uppercase text-[10px]">Cancel</button>
                <button id="finalAbortBtn"
                    class="flex-1 py-4 bg-red-600 text-white font-black rounded-2xl shadow-lg uppercase text-[10px]">Terminate
                    Run</button>
            </div>
        </div>
    </div>

    <script id="initial-data" type="application/json"><%- JSON.stringify({ scans }).replace(/</g, '\\u003c') %></script>
    <script>
        const PROJECT_ID = "<%= project.id %>";
        const initial = JSON.parse(document.getElementById('initial-data').textContent);
        let pendingAbortScan = null;
        let openConsoles = new Set();

        function toggleConsole(id) {
            const el = document.getElementById(`console-${id}`);
            if (openConsoles.has(id)) {
                openConsoles.delete(id);
                el.classList.add('hidden');
            } else {
                openConsoles.add(id);
                el.classList.remove('hidden');
            }
        }

        function renderScans(scans) {
            const list = document.getElementById('scanList');
            let html = '';
            scans.forEach(s => {
                const isActive = s.status === 'IN_PROGRESS' || s.status === 'PENDING';
                const statusColor = s.status === 'COMPLETED' ? 'text-green-600' : (s.status === 'FAILED' ? 'text-red-600' : 'text-blue-600');
                const isConsoleVisible = openConsoles.has(s.id);

                html += `
                    <div id="scan-row-${s.id}" class="bg-white rounded-[2.5rem] border-2 border-slate-100 overflow-hidden shadow-sm hover:shadow-xl hover:border-blue-500/30 transition-all duration-500">
                        <div class="p-8">
                            <div class="flex flex-wrap gap-8 items-center mb-6">
                                <div class="h-20 w-20 rounded-[1.8rem] flex items-center justify-center text-3xl font-black border-4 grade-${s.grade} shadow-sm">${s.grade}</div>
                                <div class="flex-1 min-w-[200px]">
                                    <h3 class="text-xl font-black text-slate-900 uppercase block mb-1 tracking-tighter">${s.target}</h3>
                                    <div class="flex items-center gap-4">
                                        <span class="text-status text-[10px] font-black ${statusColor} uppercase tracking-widest">${s.status}</span>
                                        <span class="text-[10px] font-bold text-slate-300 uppercase">${new Date(s.createdAt).toLocaleTimeString()}</span>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3">
                                    ${isActive ? `<button onclick="toggleConsole('${s.id}')" class="bg-slate-900 text-white p-4 rounded-2xl hover:bg-black transition-all flex items-center gap-2 text-[9px] font-black uppercase tracking-widest">
                                        <span class="h-2 w-2 rounded-full bg-green-500 animate-pulse"></span> Console
                                    </button>` : ''}
                                    ${isActive ?
                        `<button onclick="window.showAbortModal('${s.id}')" class="abort-control bg-red-50 text-red-600 p-4 rounded-2xl border border-red-100 hover:bg-red-600 hover:text-white transition-all active:scale-95">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M6 18L18 6M6 6l12 12" /></svg>
                                        </button>` :
                        `<a href="/dashboard/scan/${s.id}" class="bg-slate-50 text-slate-500 px-8 py-3 rounded-2xl text-[10px] font-black uppercase tracking-widest border-2 border-slate-100 hover:bg-slate-900 hover:text-white transition-all shadow-sm">Report</a>`
                    }
                                </div>
                            </div>

                            ${isActive ? `
                                <div class="mt-4 p-6 bg-slate-50 rounded-3xl border border-slate-100">
                                    <div class="flex justify-between items-end mb-3">
                                        <div class="flex flex-col">
                                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest mb-1">Current Protocol</span>
                                            <span class="text-xs font-black text-blue-600 uppercase italic animate-pulse tracking-tight">${s.currentStage || 'PROCESSING...'}</span>
                                        </div>
                                        <span class="text-[10px] font-black text-slate-400 tracking-widest font-mono">${s.progress || 0}%</span>
                                    </div>
                                    <div class="w-full bg-slate-200 h-3 rounded-full overflow-hidden shadow-inner">
                                        <div class="progress-bar-fill bg-blue-600 h-full rounded-full shadow-[0_0_15px_rgba(37,99,235,0.4)]" style="width: ${s.progress || 0}%"></div>
                                    </div>
                                </div>

                                <!-- MISSION CONSOLE -->
                                <div id="console-${s.id}" class="${isConsoleVisible ? '' : 'hidden'} mt-6 bg-slate-900 rounded-3xl p-6 border-b-8 border-slate-800 shadow-2xl overflow-hidden">
                                    <div class="flex items-center justify-between mb-4">
                                        <div class="flex gap-2">
                                            <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                                            <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                                            <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
                                        </div>
                                        <span class="text-[8px] font-black text-slate-500 uppercase tracking-widest font-mono">AppSec Console</span>
                                    </div>
                                    <pre class="console-scrollbar text-[10px] text-green-500/90 font-mono h-40 overflow-y-auto whitespace-pre-wrap leading-relaxed">${s.liveLogs || '[INITIALIZING TERMINAL...]'}</pre>
                                </div>
                            ` : ''}
                        </div>
                    </div>`;
            });
            list.innerHTML = html || '<div class="p-24 text-center text-slate-300 font-extrabold uppercase tracking-widest">No Intelligence Runs Registered</div>';

            // Auto-scroll consoles
            openConsoles.forEach(id => {
                const el = document.querySelector(`#console-${id} pre`);
                if (el) el.scrollTop = el.scrollHeight;
            });
        }

        window.showAbortModal = function (id) {
            pendingAbortScan = id;
            document.getElementById('abortScanIdText').textContent = `Ref: ${id}`;
            document.getElementById('abortConfirmModal').classList.remove('hidden');
        };

        document.getElementById('finalAbortBtn').addEventListener('click', async () => {
            if (!pendingAbortScan) return;
            const id = pendingAbortScan;
            const btn = document.getElementById('finalAbortBtn');
            const row = document.getElementById(`scan-row-${id}`);

            if (row) row.style.opacity = '0.4';
            btn.disabled = true; btn.textContent = 'EXECUTING...';
            document.getElementById('abortConfirmModal').classList.add('hidden');

            try {
                const res = await fetch(`${window.location.origin}/scans/${id}/cancel`, { method: 'POST' });
                if (res.ok) setTimeout(() => window.location.reload(), 1000);
            } catch (err) { window.location.reload(); }
        });

        async function refresh() {
            if (!document.getElementById('abortConfirmModal').classList.contains('hidden')) return;
            try {
                const res = await fetch(`${window.location.origin}/dashboard/project/${PROJECT_ID}/data`);
                const data = await res.json();
                renderScans(data.scans);
                document.getElementById('lastUpdated').textContent = `LIVE FEED @ ${new Date().toLocaleTimeString()}`;
            } catch (e) { }
        }

        renderScans(initial.scans);
        setInterval(refresh, 4000);

        document.getElementById('scanForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.disabled = true; btn.textContent = 'DEPLOYING...';
            try {
                const res = await fetch(`${window.location.origin}/scans`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        target: document.getElementById('target').value,
                        targetType: document.getElementById('targetType').value,
                        profile: document.getElementById('profile').value,
                        projectId: PROJECT_ID
                    })
                });
                if (res.ok) window.location.reload();
            } catch (err) { alert('Launch protocol failed.'); } finally { btn.disabled = false; btn.textContent = 'Deploy Mission'; }
        });
    </script>

</body>

</html>