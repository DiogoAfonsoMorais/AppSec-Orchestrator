<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Monitoring Active Scan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: #020617;
            color: #f8fafc;
        }

        .grade-A {
            color: #22c55e;
        }

        .grade-B {
            color: #3b82f6;
        }

        .grade-C {
            color: #eab308;
        }

        .grade-D {
            color: #f97316;
        }

        .grade-F {
            color: #ef4444;
        }

        .animate-heartbeat {
            animation: heartbeat 1.5s ease-in-out infinite;
        }

        .progress-bar-fill {
            transition: width 0.6s ease-out;
        }

        @keyframes heartbeat {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.5;
                transform: scale(1.03);
            }
        }
    </style>
</head>

<body
    class="p-8 pb-32 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-blue-900/10 via-slate-950 to-slate-950 min-h-screen">
    <div class="max-w-7xl mx-auto">
        <!-- Header -->
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-10">
            <div>
                <a href="/dashboard"
                    class="group text-blue-500 font-black text-[10px] uppercase tracking-widest flex items-center gap-2 mb-4 hover:text-blue-400 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg"
                        class="h-3 w-3 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M15 19l-7-7 7-7" />
                    </svg>
                    Return to Hub
                </a>
                <h1
                    class="text-6xl font-black italic uppercase tracking-tighter mb-2 underline decoration-blue-600 decoration-[10px] underline-offset-8">
                    War Room</h1>

            </div>

            <div class="flex gap-10 border-l-2 border-slate-800/50 pl-10">
                <div
                    class="bg-slate-900/50 border border-slate-800 p-5 rounded-3xl flex flex-col items-center min-w-[140px] backdrop-blur-md">
                    <span class="text-[9px] font-black text-slate-500 uppercase mb-1 tracking-widest">Active Runs</span>
                    <span class="text-3xl font-black text-blue-500">
                        <%= scans.filter(s=> s.status === 'IN_PROGRESS' || s.status === 'PENDING').length %>
                    </span>
                </div>
                <div
                    class="bg-slate-900/50 border border-slate-800 p-5 rounded-3xl flex flex-col items-center min-w-[140px] backdrop-blur-md">
                    <span class="text-[9px] font-black text-slate-500 uppercase mb-1 tracking-widest">Breaches</span>
                    <span class="text-3xl font-black text-red-500">
                        <%= scans.reduce((acc, s)=> acc + (s.counts ? (s.counts.critical || 0) + (s.counts.high || 0) :
                            0), 0) %>
                    </span>
                </div>
            </div>
        </div>

        <!-- Monitoring Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="monitoringGrid">
            <% scans.forEach(s=> { %>
                <div id="scan-row-<%= s.id %>"
                    class="bg-slate-900/40 border-2 border-slate-800/80 rounded-[3rem] p-10 shadow-2xl relative overflow-hidden flex flex-col backdrop-blur-xl transition-all duration-700 hover:border-blue-500/50">
                    <% if (s.status==='IN_PROGRESS' || s.status==='PENDING' ) { %>
                        <div
                            class="progress-bar-glow absolute top-0 left-0 h-1 w-full bg-blue-500 shadow-[0_0_15px_rgba(59,130,246,0.6)] animate-pulse">
                        </div>
                        <% } %>

                            <div class="flex justify-between items-start mb-8">
                                <div
                                    class="text-[9px] font-black text-slate-400 uppercase bg-slate-800/80 px-4 py-1.5 rounded-full border border-slate-700">
                                    <%= s.project ? s.project.name : 'Standalone' %>
                                </div>
                                <div class="text-3xl font-black grade-<%= s.grade %>">
                                    <%= s.grade %>
                                </div>
                            </div>

                            <div class="flex-1 mb-8">
                                <h3 class="text-xl font-black uppercase truncate mb-1 tracking-tighter">
                                    <%= s.target %>
                                </h3>

                                <% if (s.status==='IN_PROGRESS' || s.status==='PENDING' ) { %>
                                    <div class="mt-6 space-y-3">
                                        <div class="flex justify-between items-end">
                                            <span
                                                class="text-[10px] font-black text-blue-400 uppercase italic animate-heartbeat">
                                                <%= s.currentStage || 'ANALYZING...' %>
                                            </span>
                                            <span class="text-[10px] font-black text-slate-500 tracking-widest">
                                                <%= s.progress || 0 %>%
                                            </span>
                                        </div>
                                        <div
                                            class="w-full bg-slate-950 h-2 rounded-full overflow-hidden border border-slate-800">
                                            <div class="progress-bar-fill bg-blue-500 h-full rounded-full"
                                                style="width: <%= s.progress || 0 %>%"></div>
                                        </div>
                                    </div>
                                    <% } else { %>
                                        <div class="flex items-center gap-3 mt-4">
                                            <div
                                                class="h-2 w-2 rounded-full <%= s.status === 'COMPLETED' ? 'bg-green-500' : 'bg-red-500' %>">
                                            </div>
                                            <span class="text-[10px] font-black uppercase text-slate-500">
                                                <%= s.status %>
                                            </span>
                                        </div>
                                        <% } %>
                            </div>

                            <div
                                class="bg-black/40 p-5 rounded-[2rem] border border-slate-800/50 flex gap-4 items-center mt-auto">
                                <div class="flex-1">
                                    <p class="text-[9px] font-black text-slate-600 uppercase mb-1">Score</p>
                                    <p class="text-2xl font-black">
                                        <%= s.score %>
                                    </p>
                                </div>
                                <div class="h-10 w-px bg-slate-800"></div>
                                <div class="flex gap-2">
                                    <% if (s.status==='IN_PROGRESS' || s.status==='PENDING' ) { %>
                                        <button onclick="window.showAbortModal('<%= s.id %>')"
                                            class="bg-slate-900 hover:bg-red-600 border border-slate-800 text-red-500 hover:text-white p-3.5 rounded-2xl transition-all shadow-xl active:scale-95">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
                                                viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
                                                    d="M6 18L18 6M6 6l12 12" />
                                            </svg>
                                        </button>
                                        <% } else { %>
                                            <a href="/dashboard/scan/<%= s.id %>"
                                                class="bg-blue-600/10 hover:bg-blue-600 border border-blue-600/20 text-blue-400 hover:text-white p-3.5 rounded-2xl transition-all">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
                                                    viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                                                </svg>
                                            </a>
                                            <% } %>
                                </div>
                            </div>
                </div>
                <% }); %>
        </div>
    </div>

    <!-- ABORT MODAL (HARDENED) -->
    <div id="abortConfirmModal"
        class="hidden fixed inset-0 z-[200] flex items-center justify-center p-6 bg-slate-950/90 backdrop-blur-3xl">
        <div class="bg-slate-900 border-2 border-red-900/50 rounded-[3rem] w-full max-w-sm p-12 text-center shadow-2xl">
            <div class="text-6xl mb-6">🛸🛑</div>
            <h3 class="text-2xl font-black text-white mb-2 uppercase tracking-tighter italic">Abort Scan?</h3>
            <p id="abortScanIdText"
                class="text-[9px] font-bold text-slate-500 mb-10 uppercase tracking-widest font-mono"></p>
            <div class="flex gap-4">
                <button onclick="document.getElementById('abortConfirmModal').classList.add('hidden')"
                    class="flex-1 py-4 bg-slate-800 text-slate-400 font-black rounded-2xl uppercase text-[10px]">Cancel</button>
                <button id="finalAbortBtn"
                    class="flex-1 py-4 bg-red-600 text-white font-black rounded-2xl shadow-lg shadow-red-900/40 uppercase text-[10px]">Kill
                    Mission</button>
            </div>
        </div>
    </div>

    <script id="initial-data" type="application/json"><%- JSON.stringify({ scans }).replace(/</g, '\\u003c') %></script>
    <script>
        const initial = JSON.parse(document.getElementById('initial-data').textContent);
        let pendingAbortScan = null;

        window.showAbortModal = function (id) {
            pendingAbortScan = id;
            document.getElementById('abortScanIdText').textContent = `Target Ref: ${id}`;
            document.getElementById('abortConfirmModal').classList.remove('hidden');
        };

        document.getElementById('finalAbortBtn').addEventListener('click', async () => {
            if (!pendingAbortScan) return;
            const id = pendingAbortScan;
            const btn = document.getElementById('finalAbortBtn');
            const row = document.getElementById(`scan-row-${id}`);

            if (row) row.style.opacity = '0.3';
            btn.disabled = true; btn.textContent = 'EXECUTING...';
            document.getElementById('abortConfirmModal').classList.add('hidden');

            try {
                const res = await fetch(`${window.location.origin}/scans/${id}/cancel`, { method: 'POST' });
                if (res.ok) setTimeout(() => window.location.reload(), 1500);
            } catch (err) { window.location.reload(); }
        });

        // Live Monitoring 6s
        setInterval(() => {
            if (document.getElementById('abortConfirmModal').classList.contains('hidden')) {
                window.location.reload();
            }
        }, 8000);
    </script>

</body>

</html>